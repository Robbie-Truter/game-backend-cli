generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---
enum GameStatus {
  UPCOMING
  RELEASED
}

enum PreOrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

// --- Table Schemas ---
model User {
  id                        Int @id @default(autoincrement())
  email                     String  @unique
  username                  String  @unique
  passwordHash              String
  role                      String  @default("user")

  //Relations
  preOrders                 PreOrder[]
  libraryItems              LibraryItem[]
  refreshTokens             RefreshToken[]
}

model Game {
  id                        Int @id @default(autoincrement())
  title                     String @unique
  releaseDate               DateTime
  maxPreorders              Int
  status                    GameStatus

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  preOrders                 PreOrder[]
  libraryItems              LibraryItem[]
}

model PreOrder {
  id                        Int @id @default(autoincrement())

  // Timestamps
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  //User Relations
  user                      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                    Int

  //Game Relations
  game                      Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId                    Int

  status                    PreOrderStatus @default(PENDING)

  @@unique([userId, gameId])
}

model LibraryItem {
  id                        Int @id @default(autoincrement())

  // Timestamps
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  //User Relations
  user                      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                    Int

  //Game Relations
  game                      Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId                    Int

  @@unique([userId, gameId])
}

// Can store multiple refresh tokens for each user
model RefreshToken {
  id                        Int @id @default(autoincrement())
  tokenHash                 String

  // Timestamps
  createdAt                 DateTime @default(now())
  expiresAt                 DateTime

  // Metadata
  device                    String?

  //User Relations
  user                      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                    Int

  @@index([userId])
}